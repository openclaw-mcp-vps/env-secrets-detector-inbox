# Required billing settings
NEXT_PUBLIC_STRIPE_PAYMENT_LINK=https://buy.stripe.com/test_XXX
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_XXXXXXXXXXXXXXXXXXXXXXXX
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional but recommended for webhook verification + checkout session verification
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Gmail OAuth (required for inbox scanning)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Optional. If omitted, callback defaults to <origin>/api/auth/gmail
GOOGLE_REDIRECT_URI=

# App secrets
APP_SECRET=replace-with-a-long-random-secret
# Max number of Gmail messages scanned per job
SCAN_MAX_MESSAGES=1000
